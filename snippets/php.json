    "description": "Pico CMS: โครงสร้าง PHP Plugin class พร้อม DI",
    "body": [
      "<?php",
      "",
      "/**",
      " * ${1:Plugin Name}",
      " *",
      " * @author  ${2:Your Name}",
      " * @link    ${3:https://yoursite.com}",
      " * @license ${4:MIT}",
      " * @version ${5:1.0.0}",
      " */",
      "class ${6:MyPlugin} extends AbstractPicoPlugin",
      "{",
      "    const API_VERSION = 3;",
      "",
      "    protected \\$enabled = true;",
      "",
      "    protected \\$dependsOn = [];",
      "",
      "    public function onConfigLoaded(array &\\$config): void",
      "    {",
      "        $0",
      "    }",
      "}"
    ]
  },
