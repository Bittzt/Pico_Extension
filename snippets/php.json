  "!login — Login Handler": {
    "prefix": "!login",
    "description": "Pico CMS: PHP Login handler + CSRF",
    "body": [
      "<?php",
      "session_start();",
      "",
      "if (\\$_SERVER['REQUEST_METHOD'] === 'POST') {",
      "    \\$username = trim(\\$_POST['username'] ?? '');",
      "    \\$password = \\$_POST['password'] ?? '';",
      "    \\$token    = \\$_POST['csrf_token'] ?? '';",
      "",
      "    if (!hash_equals(\\$_SESSION['csrf_token'] ?? '', \\$token)) {",
      "        \\$error = 'Invalid request.';",
      "    } elseif (empty(\\$username) || empty(\\$password)) {",
      "        \\$error = 'Please fill in all fields.';",
      "    } else {",
      "        // TODO: Replace with your actual user lookup",
      "        if (\\$username === '${1:admin}' && password_verify(\\$password, '${2:hash}')) {",
      "            session_regenerate_id(true);",
      "            \\$_SESSION['user'] = \\$username;",
      "            \\$_SESSION['logged_in'] = true;",
      "            header('Location: ${3:/dashboard}');",
      "            exit;",
      "        } else {",
      "            \\$error = 'Invalid username or password.';",
      "        }",
      "    }",
      "}",
      "",
      "if (empty(\\$_SESSION['csrf_token'])) {",
      "    \\$_SESSION['csrf_token'] = bin2hex(random_bytes(32));",
      "}",
      "$0"
    ]
  },
  "!register — Register Handler": {
    "prefix": "!register",
    "description": "Pico CMS: PHP Register handler + validation",
    "body": [
      "<?php",
      "session_start();",
      "",
      "if (\\$_SERVER['REQUEST_METHOD'] === 'POST') {",
      "    \\$username = trim(\\$_POST['username'] ?? '');",
      "    \\$email    = trim(\\$_POST['email'] ?? '');",
      "    \\$password = \\$_POST['password'] ?? '';",
      "    \\$confirm  = \\$_POST['confirm_password'] ?? '';",
      "    \\$token    = \\$_POST['csrf_token'] ?? '';",
      "",
      "    if (!hash_equals(\\$_SESSION['csrf_token'] ?? '', \\$token)) {",
      "        \\$error = 'Invalid request.';",
      "    } elseif (empty(\\$username) || empty(\\$email) || empty(\\$password)) {",
      "        \\$error = 'Please fill in all fields.';",
      "    } elseif (!filter_var(\\$email, FILTER_VALIDATE_EMAIL)) {",
      "        \\$error = 'Invalid email address.';",
      "    } elseif (strlen(\\$password) < ${1:8}) {",
      "        \\$error = 'Password must be at least ${1:8} characters.';",
      "    } elseif (\\$password !== \\$confirm) {",
      "        \\$error = 'Passwords do not match.';",
      "    } else {",
      "        \\$hashed = password_hash(\\$password, PASSWORD_BCRYPT);",
      "        // TODO: Save user to your storage",
      "        $0",
      "        \\$success = 'Registration successful!';",
      "    }",
      "}",
      "",
      "if (empty(\\$_SESSION['csrf_token'])) {",
      "    \\$_SESSION['csrf_token'] = bin2hex(random_bytes(32));",
      "}"
    ]
  },
  "!forgot — Forgot Password": {
    "prefix": "!forgot",
    "description": "Pico CMS: PHP Forgot password + token generation",
    "body": [
      "<?php",
      "session_start();",
      "",
      "if (\\$_SERVER['REQUEST_METHOD'] === 'POST') {",
      "    \\$email = trim(\\$_POST['email'] ?? '');",
      "    \\$token = \\$_POST['csrf_token'] ?? '';",
