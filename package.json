{
  "name": "pico-helper",
  "displayName": "Pico Helper",
  "description": "Tools for creating Pico CMS content/themes: new Markdown with front matter, live preview, basic lint, snippets & autocomplete.",
  "version": "0.0.13",
  "publisher": "bittzt",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pico",
    "cms",
    "twig",
    "markdown",
    "lint",
    "preview",
    "snippet",
    "autocomplete",
    "static site",
    "generator"
  ],
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Bittzt/Pico_Extension"
  },
  "bugs": {
    "url": "https://github.com/Bittzt/Pico_Extension/issues"
  },
  "homepage": "https://github.com/Bittzt/Pico_Extension#readme",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:pico-helper.openSidebar",
    "onCommand:pico-helper.helloWorld",
    "onCommand:pico-helper.createMarkdown",
    "onCommand:pico-helper.preview",
    "onCommand:pico-helper.lintFile",
    "onCommand:pico-helper.login",
    "onCommand:pico-helper.register",
    "onCommand:pico-helper.forgot",
    "onCommand:pico-helper.contact",
    "onCommand:pico-helper.profile",
    "onCommand:pico-helper.logout",
    "onCommand:pico-helper.openMarkdownSnippets",
    "onCommand:pico-helper.openTwigSnippets",
    "onCommand:pico-helper.openPhpSnippets",
    "onCommand:pico-helper.plugin",
    "onCommand:pico-helper.layout",
    "onCommand:pico-helper.nav",
    "onCommand:pico-helper.pagelist",
    "onCommand:pico-helper.page",
    "onCommand:pico-helper.blog",
    "onLanguage:markdown",
    "onLanguage:twig",
    "onLanguage:php"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pico-helper-container",
          "title": "Pico Helper",
          "icon": "$(layers)"
        }
      ]
    },
    "views": {
      "pico-helper-container": [
        {
          "id": "pico-helper-sidebar",
          "name": "Pico Helper",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "pico-helper.openSidebar",
        "title": "Pico Helper: เปิด Sidebar"
      },
      {
        "command": "pico-helper.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "pico-helper.createMarkdown",
        "title": "Pico CMS: สร้าง Markdown ใหม่"
      },
      {
        "command": "pico-helper.preview",
        "title": "Pico: Live Preview (Markdown)"
      },
      {
        "command": "pico-helper.lintFile",
        "title": "Pico: Lint/ตรวจสอบไฟล์ปัจจุบัน"
      },
      {
        "command": "pico-helper.login",
        "title": "Pico: Login Template"
      },
      {
        "command": "pico-helper.register",
        "title": "Pico: Register Template"
      },
      {
        "command": "pico-helper.forgot",
        "title": "Pico: Forgot Password Template"
      },
      {
        "command": "pico-helper.contact",
        "title": "Pico: Contact Form Template"
      },
      {
        "command": "pico-helper.profile",
        "title": "Pico: Profile Template"
      },
      {
        "command": "pico-helper.logout",
        "title": "Pico: Logout Template"
      },
      {
        "command": "pico-helper.openMarkdownSnippets",
        "title": "Pico: Open Markdown Snippets"
      },
      {
        "command": "pico-helper.openTwigSnippets",
        "title": "Pico: Open Twig Snippets"
      },
      {
        "command": "pico-helper.openPhpSnippets",
        "title": "Pico: Open PHP Snippets"
      },
      {
        "command": "pico-helper.plugin",
        "title": "Pico CMS: Create Plugin"
      },
      {
        "command": "pico-helper.layout",
        "title": "Pico CMS: Create Layout"
      },
      {
        "command": "pico-helper.nav",
        "title": "Pico CMS: Create Nav"
      },
      {
        "command": "pico-helper.pagelist",
        "title": "Pico CMS: Create Page List"
      },
      {
        "command": "pico-helper.page",
        "title": "Pico CMS: Create Page"
      },
      {
        "command": "pico-helper.blog",
        "title": "Pico CMS: Create Blog"
      }
    ],
    "keybindings": [
      {
        "command": "pico-helper.openSidebar",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u"
      },
      {
        "command": "pico-helper.preview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus && editorLangId == 'markdown'"
      },
      {
        "command": "pico-helper.lintFile",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus && (editorLangId == 'markdown' || editorLangId == 'twig')"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pico-helper.preview",
          "group": "navigation@9",
          "when": "resourceLangId == 'markdown'"
        },
        {
          "command": "pico-helper.lintFile",
          "group": "navigation@10",
          "when": "resourceLangId == 'markdown' || resourceLangId == 'twig'"
        }
      ],
      "editor/context": [
        {
          "command": "pico-helper.preview",
          "group": "navigation@9",
          "when": "resourceLangId == 'markdown'"
        },
        {
          "command": "pico-helper.lintFile",
          "group": "navigation@10",
          "when": "resourceLangId == 'markdown' || resourceLangId == 'twig'"
        }
      ]
    },
    "languages": [
      {
        "id": "twig",
        "aliases": [
          "Twig"
        ],
        "extensions": [
          ".twig"
        ]
      }
    ],
    "snippets": [
      {
        "language": "twig",
        "path": "./snippets/twig.json"
      },
      {
        "language": "html",
        "path": "./snippets/twig.json"
      },
      {
        "language": "markdown",
        "path": "./snippets/markdown.json"
      },
      {
        "language": "php",
        "path": "./snippets/php.json"
      }
    ],
    "configurationDefaults": {
      "[markdown]": {
        "editor.snippetSuggestions": "top",
        "editor.suggestOnTriggerCharacters": true,
        "editor.quickSuggestions": {
          "other": true,
          "comments": true,
          "strings": true
        },
        "editor.quickSuggestionsDelay": 0,
        "editor.wordBasedSuggestions": "off"
      },
      "[twig]": {
        "editor.snippetSuggestions": "top",
        "editor.suggestOnTriggerCharacters": true,
        "editor.quickSuggestions": {
          "other": true,
          "comments": true,
          "strings": true
        },
        "editor.quickSuggestionsDelay": 0,
        "editor.wordBasedSuggestions": "off"
      },
      "[php]": {
        "editor.snippetSuggestions": "top",
        "editor.suggestOnTriggerCharacters": true,
        "editor.quickSuggestions": {
          "other": true,
          "comments": true,
          "strings": true
        },
        "editor.quickSuggestionsDelay": 0,
        "editor.wordBasedSuggestions": "off"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src || true",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.19.0",
    "typescript": "^5.7.3"
  }
}
